# Toggle the entire ad system (set to "true" to enable)
NEXT_PUBLIC_ADSTERRA_ENABLED=true

# Adsterra Publisher Keys
# Get them from: https://publishers.adsterra.com → "Ad Units" / "Get Code"
# Replace the empty values below with your real keys, then flip ENABLED to "true".

# Site-wide / background formats
NEXT_PUBLIC_ADSTERRA_POPUNDER_KEY=
NEXT_PUBLIC_ADSTERRA_SOCIAL_BAR_KEY=
NEXT_PUBLIC_ADSTERRA_INPAGE_PUSH_KEY=
NEXT_PUBLIC_ADSTERRA_INTERSTITIAL_KEY=

# Inline display banners
NEXT_PUBLIC_ADSTERRA_BANNER_300x250_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_728x90_KEY=
NEXT_PUBLIC_ADSTERRA_BANNER_160x300_KEY=

# Native banner (in-content)
NEXT_PUBLIC_ADSTERRA_NATIVE_KEY=

NEXT_PUBLIC_ADSTERRA_SMARTLINK_URL=

# EffectiveCPM Network (alternative ad network)
# Direct ad scripts (popunder / social bar / etc. — single .js payloads)
NEXT_PUBLIC_ECPM_AD_1_URL=
NEXT_PUBLIC_ECPM_AD_2_URL=
# Native banner (invoke.js + container div pattern)
NEXT_PUBLIC_ECPM_NATIVE_KEY=
NEXT_PUBLIC_ECPM_NATIVE_SCRIPT_URL=
